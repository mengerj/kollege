# Kollege configuration — copy to .env and adjust. NEVER commit .env.
# All settings are read via src/kollege/config.py (pydantic-settings), prefix KOLLEGE_.

# --- LLM / Agent ---
# Provider: "ollama" (lokal-first default) | "anthropic" | "openai" | "openrouter"
KOLLEGE_LLM_PROVIDER=ollama
# Model name as understood by the provider.
#   ollama:     e.g. "qwen2.5:7b-instruct" (tool-calling capable) — pull via `ollama pull`
#   anthropic:  e.g. "claude-sonnet-4-6"
#   openrouter: e.g. "mistralai/mistral-large" — see docs/benchmark.md
KOLLEGE_LLM_MODEL=qwen2.5:7b-instruct
# OpenAI-compatible base URL for Ollama.
KOLLEGE_OLLAMA_BASE_URL=http://localhost:11434/v1
# Cloud keys (only if provider is anthropic/openai). Leave empty for lokal-first.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- OpenRouter (nur Benchmark-Entdeckungsphase, siehe docs/benchmark.md) ---
# Bewusst KEIN Produktions-Fundament (US-Intermediär, kein sauberer EU-AVV).
# KOLLEGE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# KOLLEGE_OPENROUTER_API_KEY=

# --- Storage ---
KOLLEGE_DB_PATH=data/kollege.db
KOLLEGE_MARKDOWN_DIR=data/projects

# --- Signal (Phase 1, via signal-cli-rest-api Docker container) ---
KOLLEGE_SIGNAL_API_URL=http://localhost:8080
# Your linked Signal number in international format, e.g. +49170...
KOLLEGE_SIGNAL_NUMBER=

# --- E-Mail (Phase 2, t-online IMAP read-only) ---
# KOLLEGE_IMAP_HOST=secureimap.t-online.de
# KOLLEGE_IMAP_PORT=993
# KOLLEGE_IMAP_USER=
# KOLLEGE_IMAP_PASSWORD=

# --- LLM-Traces (Schritt 8.21, Live-Debugging) ---
# Opt-in, enthält Volltext (Prompts/Tool-Calls) — Datensparsamkeit (Prinzip 5):
# nur für Debugging-Phasen aktivieren, siehe docs/live-testing-guide.md §3e.
# KOLLEGE_TRACE=1
# KOLLEGE_TRACE_DIR=data/traces

# --- Proaktive Erinnerungen (Schritt 8.27) ---
# TOML-Datei mit dem Zeitplan (Ping/Aufgabenliste je Wochentag+Uhrzeit).
# Beispiel zum Kopieren: docs/reminders.example.toml. Fehlt die Datei, werden
# keine Erinnerungen versendet.
# KOLLEGE_REMINDERS_CONFIG_PATH=data/reminders.toml
